# Variables de entorno para Cuéntame un Cuento
#
# COPIA este archivo como `.env` y pon tus claves reales.
# ¡No subas `.env` a ningún repositorio!

# Clave para entrar al panel /admin (elige una fuerte y única)
ADMIN_KEY=

# Clave de la API de Luma (NO compartas este valor)
LUMA_API_KEY=luma-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

