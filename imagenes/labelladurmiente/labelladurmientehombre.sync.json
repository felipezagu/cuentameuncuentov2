  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "El rey y la reina celebraron el nacimiento de Aurora.",
      "endSec": 4.319
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 4.319,
      "text": "Invitaron a las hadas.",
      "endSec": 6.199
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 6.199,
      "text": "Cada una le dio un don.",
      "endSec": 8.42
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 8.42,
      "text": "La bruja Maléfica no fue invitada y lanzó un hechizo.",
      "endSec": 13.239
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 13.239,
      "text": "La princesa se pincharía con una rueca y dormiría hasta un beso de amor verdadero.",
      "endSec": 20.219
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 20.219,
      "text": "Una hada suavizó el hechizo para que no fuera para siempre.",
      "endSec": 24.799
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 24.799,
      "text": "El rey mandó esconder todas las ruecas.",
      "endSec": 28.199
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 28.199,
      "text": "Las hadas llevaron a Aurora al bosque con el nombre de Rosa.",
      "endSec": 32.639
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 32.639,
      "text": "Allí creció feliz y un día conoció al príncipe Felipe sin saber que estaban prometidos.",
      "endSec": 39.599
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 39.599,
      "text": "El día de sus dieciséis años, Aurora volvió al castillo.",
      "endSec": 43.759
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 43.759,
      "text": "Encontró una rueca, tocó el huso y se pinchó.",
      "endSec": 48.439
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 48.439,
      "text": "Cayó en un sueño profundo y todo el reino se durmió.",
      "endSec": 52.959
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 52.959,
      "text": "Maléfica intentó que el príncipe no llegara.",
      "endSec": 56.139
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 56.139,
      "text": "Felipe escapó con la ayuda de las hadas, llegó al castillo y venció los obstáculos.",
      "endSec": 63.059
    },
    {
      "index": 14,
      "sceneIndex": 3,
      "startSec": 63.059,
      "text": "Maléfica se desvaneció y las espinas se abrieron.",
      "endSec": 67.879
    },
    {
      "index": 15,
      "sceneIndex": 3,
      "startSec": 67.879,
      "text": "Felipe besó a Aurora y ella despertó.",
      "endSec": 72.279
    },
    {
      "index": 16,
      "sceneIndex": 3,
      "startSec": 72.279,
      "text": "Todo el reino despertó con ella.",
      "endSec": 75.259
    },
    {
      "index": 17,
      "sceneIndex": 3,
      "startSec": 75.259,
      "text": "Se casaron y vivieron felices para siempre",
      "endSec": 78.599
    }
  ]
}
