  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "El rey y la reina celebraron el nacimiento de Aurora.",
      "endSec": 4.48
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 4.48,
      "text": "Invitaron a las hadas.",
      "endSec": 6.259
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 6.259,
      "text": "Cada una le dio un don.",
      "endSec": 8.079
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 8.079,
      "text": "La bruja Maléfica no fue invitada y lanzó un hechizo.",
      "endSec": 12.739
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 12.739,
      "text": "La princesa se pincharía con una rueca y dormiría hasta un beso de amor verdadero.",
      "endSec": 19.5
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 19.5,
      "text": "Una hada suavizó el hechizo para que no fuera para siempre.",
      "endSec": 24.119
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 24.119,
      "text": "El rey mandó esconder todas las ruecas.",
      "endSec": 27.879
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 27.879,
      "text": "Las hadas llevaron a Aurora al bosque con el nombre de Rosa.",
      "endSec": 32.04
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 32.04,
      "text": "Allí creció feliz y un día conoció al príncipe Felipe sin saber que estaban prometidos.",
      "endSec": 39.719
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 39.719,
      "text": "El día de sus dieciséis años, Aurora volvió al castillo, encontró una rueca, tocó el huso y se pinchó.",
      "endSec": 47.879
    },
    {
      "index": 10,
      "sceneIndex": 2,
      "startSec": 47.879,
      "text": "Cayó en un sueño profundo y todo el reino se durmió.",
      "endSec": 52.479
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 52.479,
      "text": "Maléfica intentó que el príncipe no llegara.",
      "endSec": 56.18
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 56.18,
      "text": "Felipe escapó con la ayuda de las hadas.",
      "endSec": 59.239
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 59.239,
      "text": "Llegó al castillo y venció los obstáculos.",
      "endSec": 62.619
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 62.619,
      "text": "Maléfica se desvaneció y las espinas se abrieron.",
      "endSec": 67.04
    },
    {
      "index": 15,
      "sceneIndex": 3,
      "startSec": 67.04,
      "text": "Felipe besó a Aurora y ella despertó.",
      "endSec": 71.139
    },
    {
      "index": 16,
      "sceneIndex": 3,
      "startSec": 71.139,
      "text": "Todo el reino despertó con ella.",
      "endSec": 73.879
    },
    {
      "index": 17,
      "sceneIndex": 3,
      "startSec": 73.879,
      "text": "Se casaron y vivieron felices para siempre.",
      "endSec": 77.559
    }
  ]
}
