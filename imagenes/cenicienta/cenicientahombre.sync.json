  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "Cenicienta vivía con su madrastra y sus hermanastras, que la hacían trabajar mucho.",
      "endSec": 6.699
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 6.699,
      "text": "Dormía en la buhardilla.",
      "endSec": 8.519
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 8.519,
      "text": "A pesar de todo, era bondadosa y soñaba con una vida mejor.",
      "endSec": 13.659
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 13.659,
      "text": "El rey organizó un gran baile.",
      "endSec": 15.96
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 15.96,
      "text": "Las hermanastras se vistieron de gala y se burlaron de Cenicienta.",
      "endSec": 20.979
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 20.979,
      "text": "Su hada madrina apareció y convirtió una calabaza en carroza y sus harapos en vestido de cristal.",
      "endSec": 28.059
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 28.059,
      "text": "Le dijo que a medianoche todo volvería a su forma.",
      "endSec": 31.959
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 31.959,
      "text": "Cenicienta llegó al baile y el príncipe no apartó los ojos de ella.",
      "endSec": 37.52
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 37.52,
      "text": "Bailaron toda la noche.",
      "endSec": 39.979
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 39.979,
      "text": "Al dar las doce, Cenicienta salió corriendo y perdió un zapatito de cristal.",
      "endSec": 45.599
    },
    {
      "index": 10,
      "sceneIndex": 2,
      "startSec": 45.599,
      "text": "El príncipe lo recogió y juró encontrar a su dueña.",
      "endSec": 50.659
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 50.659,
      "text": "El príncipe hizo probar el zapato a todas las jóvenes.",
      "endSec": 55.059
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 55.059,
      "text": "En casa de Cenicienta, las hermanastras probaron sin éxito.",
      "endSec": 59.079
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 59.079,
      "text": "El príncipe preguntó si había otra joven.",
      "endSec": 62.239
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 62.239,
      "text": "Cenicienta bajó de la buhardilla.",
      "endSec": 64.779
    },
    {
      "index": 15,
      "sceneIndex": 3,
      "startSec": 64.779,
      "text": "Cenicienta se calzó el zapatito y sacó el otro.",
      "endSec": 68.839
    },
    {
      "index": 16,
      "sceneIndex": 3,
      "startSec": 68.839,
      "text": "El hada la vistió de nuevo.",
      "endSec": 71.059
    },
    {
      "index": 17,
      "sceneIndex": 3,
      "startSec": 71.059,
      "text": "El príncipe la reconoció.",
      "endSec": 73.72
    },
    {
      "index": 18,
      "sceneIndex": 3,
      "startSec": 73.72,
      "text": "Se casaron y Cenicienta perdonó a su familia.",
      "endSec": 78.68
    },
    {
      "index": 19,
      "sceneIndex": 3,
      "startSec": 78.68,
      "text": "Vivieron felices para siempre",
      "endSec": 81.699
    }
  ]
}
