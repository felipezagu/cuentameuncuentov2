  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "Gepetto era un carpintero que no tenía hijos.",
      "endSec": 4.059
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 4.059,
      "text": "Talló un muñeco de madera llamado Pinocho.",
      "endSec": 8.0
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 8.0,
      "text": "Un hada azul le dio vida y le dijo que sería un niño de verdad si era valiente y sincero.",
      "endSec": 14.699
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 14.699,
      "text": "Dejó a Pepito Grillo como su conciencia.",
      "endSec": 18.039
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 18.039,
      "text": "Pinocho fue al colegio, pero se dejó engañar y acabó en un teatro.",
      "endSec": 23.319
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 23.319,
      "text": "Cuando mentía, le crecía la nariz.",
      "endSec": 26.059
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 26.059,
      "text": "El hada lo perdonó.",
      "endSec": 28.039
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 28.039,
      "text": "Gepetto salió a buscarlo y fue a parar dentro de una ballena grande.",
      "endSec": 33.419
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 33.419,
      "text": "Pinocho entró en la ballena y encontró a Gepetto.",
      "endSec": 37.819
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 37.819,
      "text": "Para salir, hicieron una fogata.",
      "endSec": 40.239
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 40.239,
      "text": "El humo hizo estornudar a la ballena y los expulsó al mar.",
      "endSec": 44.459
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 44.459,
      "text": "Nadaron hasta la orilla.",
      "endSec": 46.759
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 46.759,
      "text": "En casa, Gepetto estaba muy cansado.",
      "endSec": 49.799
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 49.799,
      "text": "Pinocho lo cuidó día y noche.",
      "endSec": 52.779
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 52.779,
      "text": "Demostró que era valiente y sincero.",
      "endSec": 56.119
    },
    {
      "index": 15,
      "sceneIndex": 2,
      "startSec": 56.119,
      "text": "El hada premió a Pinocho convirtiéndolo en un niño de verdad.",
      "endSec": 61.279
    },
    {
      "index": 16,
      "sceneIndex": 2,
      "startSec": 61.279,
      "text": "Gepetto y Pepito Grillo estaban muy contentos.",
      "endSec": 65.519
    },
    {
      "index": 17,
      "sceneIndex": 3,
      "startSec": 65.519,
      "text": "La honestidad y el amor hacen que los sueños se cumplan.",
      "endSec": 69.839
    }
  ]
