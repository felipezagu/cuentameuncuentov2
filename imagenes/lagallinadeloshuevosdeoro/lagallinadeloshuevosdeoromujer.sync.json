  "note": "Generado automáticamente desde ElevenLabs Speech-to-Text (timestamps word).",
  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.099,
      "text": "Un granjero y su mujer tenían una gallina muy especial.",
      "endSec": 4.819
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 4.819,
      "text": "Cada mañana ponía un huevo de oro.",
      "endSec": 7.759
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 7.759,
      "text": "Vendían el huevo y vivían muy bien.",
      "endSec": 10.88
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 10.88,
      "text": "Pero empezaron a pensar: si tiene oro dentro, ¿por qué no quedarnos con todo de una vez?",
      "endSec": 16.92
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 16.92,
      "text": "La mujer insistía: así seremos ricos de una vez.",
      "endSec": 21.02
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 21.02,
      "text": "El granjero dudaba, pero al final aceptó.",
      "endSec": 24.479
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 24.479,
      "text": "Por querer todo el oro de una vez, perdieron a la gallina para siempre.",
      "endSec": 30.0
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 30.0,
      "text": "No había montañas de oro, era una gallina como las demás.",
      "endSec": 34.239
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 34.239,
      "text": "Los dos se quedaron mirando sin creerlo.",
      "endSec": 37.899
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 37.899,
      "text": "Habían perdido a la gallina que cada día les daba un huevo de oro.",
      "endSec": 42.34
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 42.34,
      "text": "Ya no tendrían ni un huevo más.",
      "endSec": 45.099
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 45.099,
      "text": "Se arrepintieron mucho, pero era tarde.",
      "endSec": 48.059
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 48.059,
      "text": "La avaricia rompe el saco.",
      "endSec": 50.579
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 50.579,
      "text": "Quien no sabe esperar y quiere todo de golpe puede perder lo que ya tenía.",
      "endSec": 56.739
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 56.739,
      "text": "Es mejor valorar lo que tenemos y no arriesgarlo por codicia.",
      "endSec": 61.059
    }
  ]
}
