  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "Un perro encontró un hueso jugoso y lo cogió en la boca para llevarlo a un lugar tranquilo.",
      "endSec": 7.339
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 7.339,
      "text": "Cruzaba un puente sobre un río cuando miró hacia abajo.",
      "endSec": 11.3
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 11.3,
      "text": "En el agua vio el reflejo de otro perro con otro hueso en la boca.",
      "endSec": 16.42
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 16.42,
      "text": "No entendió que era su propia imagen.",
      "endSec": 19.539
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 19.539,
      "text": "Pensó: \"Ese hueso es más grande que el mío\".",
      "endSec": 24.079
    },
    {
      "index": 5,
      "sceneIndex": 1,
      "startSec": 24.079,
      "text": "Quiso gruñir para asustar al otro perro y quedarse con su hueso.",
      "endSec": 28.639
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 28.639,
      "text": "Abrió la boca para ladrar.",
      "endSec": 30.699
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 30.699,
      "text": "En ese instante, su hueso se cayó al río y se lo llevó la corriente.",
      "endSec": 35.719
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 35.719,
      "text": "El reflejo desapareció.",
      "endSec": 38.36
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 38.36,
      "text": "El perro se quedó sin hueso y con hambre.",
      "endSec": 41.879
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 41.879,
      "text": "Había perdido lo que tenía por querer lo que creía que tenía el otro.",
      "endSec": 48.079
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 48.079,
      "text": "La codicia y la envidia nos hacen perder lo que ya tenemos.",
      "endSec": 53.379
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 53.379,
      "text": "Es mejor valorar lo nuestro y no arriesgarlo por lo que vemos en los demás.",
      "endSec": 58.799
    }
  ]
}
