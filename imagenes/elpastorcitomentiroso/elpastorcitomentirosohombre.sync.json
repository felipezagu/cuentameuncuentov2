  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "Un muchacho cuidaba las ovejas en el monte.",
      "endSec": 3.079
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 3.079,
      "text": "Se aburría y un día gritó: \"¡Que viene el lobo, que viene el lobo!\".",
      "endSec": 9.76
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 9.76,
      "text": "Los vecinos subieron corriendo con palos y no había ningún lobo.",
      "endSec": 14.34
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 14.34,
      "text": "El pastor se rió mucho.",
      "endSec": 16.319
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 16.319,
      "text": "Al cabo de unos días volvió a gritar: \"¡Que viene el lobo!\".",
      "endSec": 21.459
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 21.459,
      "text": "De nuevo los aldeanos subieron y de nuevo era mentira.",
      "endSec": 25.519
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 25.519,
      "text": "Se enfadaron y le dijeron que no volverían.",
      "endSec": 28.619
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 28.619,
      "text": "Una tarde, de verdad, apareció un lobo entre las ovejas.",
      "endSec": 32.399
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 32.399,
      "text": "El pastorcito gritó con miedo: \"¡Que viene el lobo, de verdad!",
      "endSec": 37.299
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 37.299,
      "text": "¡Ayudadme!\".",
      "endSec": 38.599
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 38.599,
      "text": "Nadie subió.",
      "endSec": 40.239
    },
    {
      "index": 11,
      "sceneIndex": 1,
      "startSec": 40.239,
      "text": "Pensaron que era otra broma.",
      "endSec": 42.399
    },
    {
      "index": 12,
      "sceneIndex": 1,
      "startSec": 42.399,
      "text": "El lobo atacó al rebaño y el pastor no pudo hacer nada solo.",
      "endSec": 47.02
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 47.02,
      "text": "Perdió varias ovejas.",
      "endSec": 49.279
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 49.279,
      "text": "Cuando bajó al pueblo llorando, le dijeron: \"Quien miente una vez no es creído cuando dice la verdad\".",
      "endSec": 56.559
    },
    {
      "index": 15,
      "sceneIndex": 2,
      "startSec": 56.559,
      "text": "El pastorcito aprendió que la mentira tiene consecuencias muy graves.",
      "endSec": 60.879
    }
  ]
}
