  "segments": [
    {
      "index": 0,
      "sceneIndex": 0,
      "startSec": 0.079,
      "text": "Un cuervo había encontrado un trozo de queso y se subió a una rama para comérselo tranquilo.",
      "endSec": 6.719
    },
    {
      "index": 1,
      "sceneIndex": 0,
      "startSec": 6.719,
      "text": "Una zorra pasaba por ahí y el olor del queso la atrajo.",
      "endSec": 11.5
    },
    {
      "index": 2,
      "sceneIndex": 0,
      "startSec": 11.5,
      "text": "La zorra no podía alcanzar al cuervo.",
      "endSec": 14.739
    },
    {
      "index": 3,
      "sceneIndex": 0,
      "startSec": 14.739,
      "text": "Entonces dijo: \"Qué plumas tan bonitas tienes y qué voz tan clara debes de tener.",
      "endSec": 21.939
    },
    {
      "index": 4,
      "sceneIndex": 0,
      "startSec": 21.939,
      "text": "Cantarías para mí\".",
      "endSec": 23.68
    },
    {
      "index": 5,
      "sceneIndex": 0,
      "startSec": 23.68,
      "text": "El cuervo se hinchó de orgullo.",
      "endSec": 25.899
    },
    {
      "index": 6,
      "sceneIndex": 1,
      "startSec": 25.899,
      "text": "El cuervo quiso demostrar su voz.",
      "endSec": 28.819
    },
    {
      "index": 7,
      "sceneIndex": 1,
      "startSec": 28.819,
      "text": "Abrió el pico para cantar y el queso se cayó al suelo.",
      "endSec": 32.899
    },
    {
      "index": 8,
      "sceneIndex": 1,
      "startSec": 32.899,
      "text": "La zorra lo cogió al vuelo y dijo: \"Con tu voz no te hace falta el queso\".",
      "endSec": 38.239
    },
    {
      "index": 9,
      "sceneIndex": 1,
      "startSec": 38.239,
      "text": "Y se marchó.",
      "endSec": 40.119
    },
    {
      "index": 10,
      "sceneIndex": 1,
      "startSec": 40.119,
      "text": "El cuervo se quedó sin queso y muy avergonzado.",
      "endSec": 44.719
    },
    {
      "index": 11,
      "sceneIndex": 2,
      "startSec": 44.719,
      "text": "Había creído los halagos y había sido engañado.",
      "endSec": 49.119
    },
    {
      "index": 12,
      "sceneIndex": 2,
      "startSec": 49.119,
      "text": "No hay que creer todo lo que nos dicen por halagos.",
      "endSec": 53.419
    },
    {
      "index": 13,
      "sceneIndex": 2,
      "startSec": 53.419,
      "text": "A veces nos adulan para sacarnos algo.",
      "endSec": 56.479
    },
    {
      "index": 14,
      "sceneIndex": 2,
      "startSec": 56.479,
      "text": "La prudencia vale más que el orgullo.",
      "endSec": 59.259
    }
  ]
}
